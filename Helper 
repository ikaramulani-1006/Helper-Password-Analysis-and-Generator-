def add_to_history(pwd, result):
    history_data = []
    try:
        history_data = json.loads(history_list.value or '[]')
    except:
        pass
   
    entry = {
        'password': pwd[:8] + '...' if len(pwd) > 8 else pwd,
        'strength': result['strength'],
        'score': result['score'],
        'time': result['timestamp'],
        'crack_time': result['time_to_crack']
    }
   
    history_data.insert(0, entry)
    history_data = history_data[:5]  # Keep only 5 recent
   
    history_html = '<div style="font-size:14px; line-height:1.4;">'
    for i, item in enumerate(history_data, 1):
        color = '#10B981' if 'ELITE' in item['strength'] else '#EF4444'
        history_html += f'''
        <div style="padding:8px; border-bottom:1px solid #eee;
                   background:rgba(0,0,0,0.05); margin:2px 0; border-radius:5px;">
            <strong style="color:{color}">#{i}</strong>
            {item["password"]} | {item["score"]}/12 | {item["crack_time"]}
        </div>
        '''
    history_html += '</div>'
    history_list.children = [widgets.HTML(history_html)]

def generate_password(b):
