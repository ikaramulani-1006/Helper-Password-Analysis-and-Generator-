        'analysis': result,
        'timestamp': datetime.now().isoformat(),
        'generated_by': 'Password Strength Analyzer Pro'
    }
   
    # Copy JSON to clipboard
    pyperclip.copy(json.dumps(export_data, indent=2))
    export_btn.description = ' Exported!'
    export_btn.button_style = 'success'
   
    def reset():
        export_btn.description = ' Export Results'
