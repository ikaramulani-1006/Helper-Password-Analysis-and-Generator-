class EnhancedPasswordAnalyzer:
    def __init__(self):
        # Top 1000 common passwords (sample)
        self.common_passwords = {
            'password', '123456', '123456789', 'guest', 'qwerty', '12345678', '111111',
            '12345', 'col123456', '123123', 'abc123', 'letmein', 'monkey', '1234567',
            'password123', 'admin', 'welcome', 'dragon', 'master', 'hello', 'freedom',
            'whatever', 'qazwsx', 'trustno1', 'prince', 'jordan', 'harley', 'ranger',
            'iwantu', 'jennifer', 'hunter', 'shadow', 'mustang', 'soccer', 'superman',
            'batman', 'andrew', 'tigger', 'sunshine', 'iloveyou', 'fuckyou', '2000',
            'charlie', 'robert', 'thomas', 'hockey', 'rangers', 'daniel', 'starwars',
            'klaster', '112233', 'george', 'asshole', 'computer', 'michelle', 'jessica',
            'pepper', '1111', 'zxcvbnm', '555555', '11111111', '131313', 'killer',
            'welcome1', 'password1', 'fuckme', '1234', 'aaron', 'flower', 'maggie',
            'animal', 'ginger', 'jackson', 'lovely', 'mike', 'please', 'pretty', 'test',
            'thunder', 'wf', 'asdfgh', 'qwer1234', '1qaz2wsx', 'aa123456', '654321',
            'login', 'qwertyuiop', 'solo', 'princesa', 'cheese', 'zxc123', 'zaq1zaq1',
            '123qwe', '321321', 'killer1', 'login1', 'pass', 'test1', 'turtle'
        }
   
    def analyze(self, password):
        if not password:
            return {'strength': 'Enter password...', 'score': 0, 'color': '#888', 'percent': 0}
       
        # 12 Criteria (Enhanced)
        checks = {
            'length': len(password) >= 12,
            'upper': bool(re.search('[A-Z]', password)),
            'lower': bool(re.search('[a-z]', password)),
            'numbers': bool(re.search('[0-9]', password)),
            'symbols': bool(re.search('[^a-zA-Z0-9]', password)),
            'no_repeat': len(set(password)) / len(password) > 0.6,
            'no_seq': not self._has_sequence(password),
            'no_common': password.lower().strip() not in self.common_passwords,
            'entropy': self._entropy(password) > 50,  # Increased threshold
            'diverse': len(self._char_types(password)) >= 3,
            'no_keyboard': not self._has_keyboard_pattern(password),
            'middle_numbers': bool(re.search(r'(?=.*[a-zA-Z])(?=.*[0-9]).*[0-9].*[a-zA-Z]|[a-zA-Z].*[0-9]', password))
        }
       
        score = sum(1 for v in checks.values() if v)
        percent = min(score * 8.33, 100)  # 100/12 ≈ 8.33
       
        if score >= 11: strength, color = '🟢🔥 ULTRA ELITE', '#10B981'
        elif score >= 10: strength, color = '🟢 ELITE', '#059669'
        elif score >= 8: strength, color = '🟢 STRONG', '#34D399'
        elif score >= 6: strength, color = '🟡 GOOD', '#F59E0B'
        elif score >= 4: strength, color = '🟠 FAIR', '#F97316'
        else: strength, color = '🔴 WEAK', '#EF4444'
       
        tips = []
        if not checks['length']: tips.append('12+ chars')
        if not checks['symbols']: tips.append('!@#$%^&*')
        if not checks['upper']: tips.append('UPPERCASE')
        if not checks['no_common']: tips.append('Avoid common words')
        if score < 6: tips.append('Try generator →')
       
        # Time to crack estimate
        time_to_crack = self._estimate_crack_time(password)
       
        return {
            'strength': strength, 'score': score, 'max_score': 12,
            'color': color, 'percent': percent, 'checks': checks,
            'tips': tips[:4], 'length': len(password),
            'time_to_crack': time_to_crack,
            'timestamp': datetime.now().strftime('%H:%M:%S')
        }
   
    def _has_sequence(self, pwd):
        seq = 'qwertyuiopasdfghjklzxcvbnm1234567890'
        return any(pwd.lower()[i:i+4] in seq+i for i in range(len(pwd)-3))
   
    def _has_keyboard_pattern(self, pwd):
        patterns = ['qwerty', 'asdf', 'zxcv', 'qaz', 'wsx', 'edc']
        return any(pattern in pwd.lower() for pattern in patterns)
   
    def _entropy(self, pwd):
        chars = len(set(pwd))
        return len(pwd) * math.log2(max(chars, 2))
   
    def _char_types(self, pwd):
        types = set()
        if re.search('[a-z]', pwd): types.add('lower')
        if re.search('[A-Z]', pwd): types.add('upper')
        if re.search('[0-9]', pwd): types.add('digit')
        if re.search('[^a-zA-Z0-9]', pwd): types.add('symbol')
        return types
   
    def _estimate_crack_time(self, pwd):
        """Rough estimate of brute-force crack time"""
        length = len(pwd)
        charset_size = 95  # Printable ASCII
        attempts_per_sec = 10**10  # Modern GPU speed
       
        total_combinations = charset_size ** length
        seconds = total_combinations / attempts_per_sec
       
        if seconds < 60:
            return f"{seconds:.1f}s"
        elif seconds < 3600:
            return f"{seconds/60:.1f}min"
        elif seconds < 86400:
            return f"{seconds/3600:.1f}h"
        elif seconds < 31536000:
            return f"{seconds/86400:.0f} days"
        else:
            return f"{seconds/31536000:.1f} years"

